# --- App ---
ENV=dev
API_HOST=0.0.0.0
API_PORT=8000

# --- Postgres ---
POSTGRES_USER=unitrack
POSTGRES_PASSWORD=unitrack
POSTGRES_DB=unitrack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Elasticsearch (GPS geo queries / analytics) ---
ELASTICSEARCH_URL=http://elasticsearch:9200
GPS_INDEX=gps_points

# --- Auth ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-prod
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30

# --- Identity ---
# Comma-separated varsity email domains allowed to register as students.
ALLOWED_STUDENT_EMAIL_DOMAINS=ulab.edu.bd

# --- External (filled in later phases) ---
# BKASH_...=
# MAPBOX_TOKEN=
# SMTP_...=
