# Production environment sample. Copy to `.env.prod` on the VPS and fill in the
# REAL values — never commit `.env.prod`.
#
#   cp .env.prod.example .env.prod   &&   nano .env.prod
#
# Used by docker-compose.prod.yml. The placeholders marked CHANGE_ME are secrets
# the whole system's safety depends on; the box gets compromised fast if they
# ship as-is.

# --- App ---
ENV=prod
API_HOST=0.0.0.0
API_PORT=8000

# --- Postgres ---
POSTGRES_USER=unitrack
# CHANGE_ME — a long random password. e.g. `openssl rand -base64 24`
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=unitrack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# CHANGE_ME — Redis runs with requirepass in prod; must match here and in
# docker-compose.prod.yml. e.g. `openssl rand -base64 24`
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200
GPS_INDEX=gps_points
# JVM heap. 512m fits a small VPS; raise if you give ES more RAM.
ES_JAVA_OPTS=-Xms512m -Xmx512m

# --- Auth ---
# CHANGE_ME — forge-anyone's-token if left default.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_generate_a_48_byte_url_safe_secret
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30

# --- Identity ---
ALLOWED_STUDENT_EMAIL_DOMAINS=ulab.edu.bd

# --- Operations ---
SERVICE_TIMEZONE=Asia/Dhaka

# --- External (later phases) ---
# BKASH_...=
# MAPBOX_TOKEN=
# SMTP_...=
